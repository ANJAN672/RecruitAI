# AI: use OpenRouter (recommended) or Gemini
# If OPENROUTER_API_KEY is set, OpenRouter is used with OPENROUTER_MODEL.
OPENROUTER_API_KEY="your_openrouter_api_key"
OPENROUTER_MODEL="google/gemini-2.0-flash"

# Else Gemini is used (GEMINI_API_KEY required)
GEMINI_API_KEY="your_gemini_api_key"
GEMINI_MODEL="gemini-2.0-flash"

# Supabase (required for DB – no server, direct Supabase)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Optional: future Naukri / LinkedIn API (when you have partner/API access)
# NAUKRI_API_KEY=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# Optional (AI Studio)
# APP_URL="MY_APP_URL"
